    if (val === '350k' || val === 350000) return 'RM350,000';
    if (val === '500k' || val === 500000) return 'RM500,000';
    if (val === '100k' || val === 100000) return 'RM100,000';
    if (typeof val === 'number') {
        if (val >= 1000000) return 'RM' + (val / 1000000).toFixed(1).replace('.0','') + ' Juta';
        return 'RM' + val.toLocaleString('ms-MY');
    }
    return val;
}

