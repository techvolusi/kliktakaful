function calculateEstimate() {
    const age    = parseInt(document.getElementById('calc_age').value);
    const hibah  = parseInt(document.getElementById('calc_hibah').value);
    const gender = document.getElementById('calc_gender').value;
    if (!age || !hibah || !gender) { alert('Sila lengkapkan semua maklumat.'); return; }
    const results  = priceDB.filter(r => r.Age === age && r.Gender === gender && r.SumCovered === hibah);
    const resultEl = document.getElementById('calc_result');
    if (results.length === 0) {
        resultEl.innerHTML = `<div class="result-error">⚠️ Tiada data untuk kombinasi ini. Sila hubungi kami untuk quotation peribadi.</div>`;
        resultEl.classList.add('show');
        return;
    }
    const validPrices = results.filter(r => r.Price !== "N/A").map(r => r.Price);
    const minPrice    = Math.min(...validPrices);
    const maxPrice    = Math.max(...validPrices);
    const hibahFormatted = formatHibahValue(hibah);
    const umurLabel = age + ' tahun';
    resultEl.innerHTML = `
        <div class="result-box">
            <div class="result-box-label">✅ &nbsp;HASIL KALKULATOR ANDA</div>
            <div class="result-meta-grid">
                <div class="result-meta-item"><div class="result-meta-item-label">Nilai Hibah</div><div class="result-meta-item-value">${hibahFormatted}</div></div>
                <div class="result-meta-item"><div class="result-meta-item-label">Umur</div><div class="result-meta-item-value">${umurLabel}</div></div>
                <div class="result-meta-item"><div class="result-meta-item-label">Jantina</div><div class="result-meta-item-value">${gender}</div></div>
            </div>
            <div class="result-amount-wrap">
                <div class="result-amount-label">Anggaran Caruman Bulanan</div>
                <div class="result-amount">RM${minPrice} – RM${maxPrice}</div>
                <div class="result-note">*Anggaran berdasarkan profil anda. Harga tepat bergantung kepada kesihatan &amp; syarikat pilihan.</div>
            </div>
            <p class="result-cta-text">Nak tahu harga tepat dari 9 syarikat?</p>
            <a href="#form" class="result-cta-btn">DAPATKAN QUOTATION SEBENAR →</a>
        </div>
    `;
    resultEl.classList.add('show');
    setTimeout(() => { resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 100);
}

document.querySelectorAll('.custom-select').forEach(function(dd) {
    const selected = dd.querySelector('.cs-selected');
    const options  = dd.querySelectorAll('.cs-option');
    const targetId = dd.dataset.target;
    selected.addEventListener('click', function(e) {
        e.stopPropagation();
        document.querySelectorAll('.custom-select').forEach(function(other) { if (other !== dd) other.classList.remove('open'); });
        dd.classList.toggle('open');
    });
    options.forEach(function(opt) {
        opt.addEventListener('click', function() {
            const val = opt.dataset.value;
            const label = opt.textContent;
            selected.innerHTML = '<span>' + label + '</span><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path stroke="#94A3B8" stroke-width="1.5" d="M1 1l5 5 5-5"/></svg>';
            document.getElementById(targetId).value = val;
            options.forEach(function(o) { o.classList.remove('selected'); });
            opt.classList.add('selected');
            dd.classList.remove('open');
        });
    });
});
document.addEventListener('click', function() {
    document.querySelectorAll('.custom-select').forEach(function(dd) { dd.classList.remove('open'); });
});
